#: src/Form/AdnoFieldset.php
msgid "Adno project URL"
msgstr "URL del proyecto Adno"

#: src/Form/AdnoFieldset.php
msgid "The address of your Adno instance. If you do not have one, you can use https://w.adno.app."
msgstr ""
"La dirección de su instancia de Adno. Si no tiene uno, puede utilizar "
"https://w.adno.app."

#: src/Form/AdnoFieldset.php
msgid "It is also possible to provide the URL of an image"
msgstr "Además es posible proporcionar la URL de una imagen"

#: src/Form/AdnoFieldset.php
msgid "Width"
msgstr "Anchura"

#: src/Form/AdnoFieldset.php
msgid "The width of the container in percentage (e.g., 100%) or in pixels (e.g., 600)."
msgstr ""
"La anchura del contenedor en porcentaje (p.ej. 100%) o en píxeles (p.ej., "
"600)."

#: src/Form/AdnoFieldset.php
msgid "Height"
msgstr "Altura"

#: src/Form/AdnoFieldset.php
msgid "The height of the container in percentage (e.g., 100%) or in pixels (e.g., 600)."
msgstr ""
"La altura del contenedor en porcentaje (p.ej., 100%) o en píxeles (p.ej., "
"600)."

#: src/Form/AdnoFieldset.php
msgid "Information"
msgstr "Información"

#: src/Form/AdnoFieldset.php
msgid "Parameters"
msgstr "Parámetros"

#: src/Form/AdnoFieldset.php
msgid "Use Adno's URL generator to override project settings. https://w.adno.app/#/link"
msgstr ""
"Utilice las URL del generador Adno para cubrir los ajustes del proyecto. "
"https://w.adno.app/#/link"

