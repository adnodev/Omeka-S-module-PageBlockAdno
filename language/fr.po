#: src/Form/AdnoFieldset.php
msgid "Adno project URL"
msgstr "URL du projet Adno"

#: src/Form/AdnoFieldset.php
msgid "The address of your Adno instance. If you do not have one, you can use https://w.adno.app."
msgstr ""
"L'adresse de votre instance Adno. Si vous n'en disposez pas, vous pouvez "
"utiliser https://w.adno.app."

#: src/Form/AdnoFieldset.php
msgid "It is also possible to provide the URL of an image"
msgstr "Il est aussi possible de fournir l'URL d'une image"

#: src/Form/AdnoFieldset.php
msgid "Width"
msgstr "Largeur"

#: src/Form/AdnoFieldset.php
msgid "The width of the container in percentage (e.g., 100%) or in pixels (e.g., 600)."
msgstr "La largeur du conteneur en pourcentage (ex. 100%) ou en pixels (ex. 600)."

#: src/Form/AdnoFieldset.php
msgid "Height"
msgstr "Hauteur"

#: src/Form/AdnoFieldset.php
msgid "The height of the container in percentage (e.g., 100%) or in pixels (e.g., 600)."
msgstr "La hauteur du conteneur en pourcentage (ex. 100%) ou en pixels (ex. 600)."

#: src/Form/AdnoFieldset.php
msgid "Information"
msgstr "Information"

#: src/Form/AdnoFieldset.php
msgid "Parameters"
msgstr "Paramètres"

#: src/Form/AdnoFieldset.php
msgid "Use Adno's URL generator to override project settings. https://w.adno.app/#/link"
msgstr ""
"Utiliser le Générateur d'URL de Adno pour surcharger les paramètres du "
"projet. https://w.adno.app/#/link"

#: src/Site/BlockLayout/Adno.php
msgid "Adno Viewer"
msgstr "Visionneuse Adno"
